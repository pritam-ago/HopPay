# Relayer Environment Variables
# Copy this to .env and fill in real values

# ── Blockchain ────────────────────────────────────────────────────────────────
RPC_URL=https://testnet.evm.nodes.onflow.org
CONTRACT_ADDRESS=0xd1Eb9CeAA265D4d2f13E4dDD815AA5fe7212fdA8
RELAYER_PRIVATE_KEY=your_relayer_wallet_private_key_here
TOKEN_NAME=MESHT
TOKEN_VERSION=1
CHAIN_ID=545

# ── Cashfree Payout API ───────────────────────────────────────────────────────
# Sign up at https://www.cashfree.com/payment-gateway
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key
# Use "TEST" for sandbox, "PROD" for production
CASHFREE_ENV=TEST

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
