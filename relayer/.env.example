# Relayer Environment Variables
# Copy this to .env and fill in real values

# ── Blockchain ────────────────────────────────────────────────────────────────
RPC_URL=https://testnet.evm.nodes.onflow.org
CONTRACT_ADDRESS=0xd1Eb9CeAA265D4d2f13E4dDD815AA5fe7212fdA8
RELAYER_PRIVATE_KEY=your_relayer_wallet_private_key_here
TOKEN_NAME=MESHT
TOKEN_VERSION=1
CHAIN_ID=545

# ── Decentro Payout API v3 ────────────────────────────────────────────────────
# Sign up at https://decentro.tech
# Get keys from: https://dashboard.decentro.tech → API Keys
# API Docs: https://docs.decentro.tech/reference/payments_api-initiate-payout-v3
# 
# v3 API requires only: client_id, client_secret, consumer_urn
# (module_secret and provider_secret are NOT needed for v3)

DECENTRO_CLIENT_ID=your_client_id
DECENTRO_CLIENT_SECRET=your_client_secret
DECENTRO_CONSUMER_URN=your_master_consumer_urn
# Use "STAGING" for sandbox, "PRODUCTION" for real transfers
DECENTRO_ENV=STAGING

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
