# Relayer Environment Variables
# Copy this to .env and fill in real values

# ── Blockchain ────────────────────────────────────────────────────────────────
RPC_URL=https://testnet.evm.nodes.onflow.org
CONTRACT_ADDRESS=0xd1Eb9CeAA265D4d2f13E4dDD815AA5fe7212fdA8
RELAYER_PRIVATE_KEY=your_relayer_wallet_private_key_here
TOKEN_NAME=MESHT
TOKEN_VERSION=1
CHAIN_ID=545

# ── Twilio SMS Configuration ──────────────────────────────────────────────────
# Sign up at https://twilio.com/try-twilio (free $15 trial credit)
# Get credentials from: https://console.twilio.com
# Verify phone numbers at: https://console.twilio.com/us1/develop/phone-numbers/manage/verified
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Phone number to send SMS notifications to (10 digits, no +91)
DEMO_MERCHANT_PHONE=9876543210

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

